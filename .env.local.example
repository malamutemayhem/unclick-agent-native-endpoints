# Copy this file to .env.local and fill in your credentials.
# Supabase: Dashboard > Project Settings > API

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Resend - used to email bug reports and review notifications
# Get your key from: https://resend.com/api-keys
# Also add this to Vercel: Settings > Environment Variables > RESEND_API_KEY
RESEND_API_KEY=re_your_api_key_here

# Admin email for internal notifications (bug reports, tool submissions)
# Also add this to Vercel: Settings > Environment Variables > ADMIN_NOTIFICATION_EMAIL
ADMIN_NOTIFICATION_EMAIL=your-admin-email@example.com

# Supabase table setup -- run this SQL in the Supabase SQL Editor:
#
# CREATE TABLE api_keys (
#   id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
#   email TEXT NOT NULL,
#   api_key TEXT NOT NULL UNIQUE,
#   created_at TIMESTAMPTZ DEFAULT NOW(),
#   status TEXT DEFAULT 'active'
# );
#
# ALTER TABLE api_keys ENABLE ROW LEVEL SECURITY;
#
# CREATE POLICY "Allow inserts" ON api_keys
#   FOR INSERT WITH CHECK (true);
#
# CREATE POLICY "Allow select by email" ON api_keys
#   FOR SELECT USING (true);
