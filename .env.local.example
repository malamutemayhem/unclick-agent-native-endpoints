# Copy this file to .env.local and fill in your credentials.
# Supabase: Dashboard > Project Settings > API

# Beta banner - shown on all pages during public beta.
# Set to "false" in Vercel env vars to hide it when you exit beta.
# Omitting the var keeps the banner visible (safe default).
VITE_BETA_BANNER_ENABLED=true

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Resend - used to email bug reports and review notifications
# Get your key from: https://resend.com/api-keys
# Also add this to Vercel: Settings > Environment Variables > RESEND_API_KEY
RESEND_API_KEY=re_your_api_key_here

# Admin email for internal notifications (bug reports, tool submissions)
# Also add this to Vercel: Settings > Environment Variables > ADMIN_NOTIFICATION_EMAIL
ADMIN_NOTIFICATION_EMAIL=your-admin-email@example.com

# Umami (self-hosted) for server-side tool-usage analytics.
# UMAMI_WEBSITE_ID: the id from the site's Umami tracking snippet in
#   index.html (the data-website-id attribute). When set, every MCP
#   tool invocation fires a fire-and-forget "tool_call" event to Umami.
#   Leave blank to disable server-side tracking (dev / local).
# UMAMI_URL: optional, defaults to https://analytics.unclick.world. Set
#   if you point at a different Umami instance (e.g. staging).
# Also add the website id to Vercel: Settings > Environment Variables.
UMAMI_WEBSITE_ID=your-umami-website-id-here
UMAMI_URL=https://analytics.unclick.world

# PostHog analytics - dual tracking alongside Umami during validation.
# Sign up at posthog.com, then: Project Settings > Project API Key (starts with phc_)
# VITE_POSTHOG_KEY and VITE_POSTHOG_HOST go to Vercel > Settings > Environment Variables.
# POSTHOG_API_KEY is for server-side capture (same phc_ key works fine).
# Leave blank to disable PostHog silently (no-op until key is set).
VITE_POSTHOG_KEY=phc_your_project_api_key
VITE_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=phc_your_project_api_key
POSTHOG_HOST=https://us.i.posthog.com

# Stripe (test mode for now).
# Dashboard > Developers > API keys for the sk_/pk_ pair.
# Dashboard > Developers > Webhooks for the whsec_ signing secret.
# Also add all three to Vercel: Settings > Environment Variables.
# Never commit the values, only the variable names.
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# Supabase table setup -- run this SQL in the Supabase SQL Editor:
#
# CREATE TABLE api_keys (
#   id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
#   email TEXT NOT NULL,
#   api_key TEXT NOT NULL UNIQUE,
#   created_at TIMESTAMPTZ DEFAULT NOW(),
#   status TEXT DEFAULT 'active'
# );
#
# ALTER TABLE api_keys ENABLE ROW LEVEL SECURITY;
#
# CREATE POLICY "Allow inserts" ON api_keys
#   FOR INSERT WITH CHECK (true);
#
# CREATE POLICY "Allow select by email" ON api_keys
#   FOR SELECT USING (true);
# ANTHROPIC_API_KEY -- used ONLY for internal Bailey/Memory-extraction jobs.
# NOT used for user-facing runs (those route via MCP sampling).
# Leave unset in local dev unless you run internal extraction jobs.
ANTHROPIC_API_KEY=
