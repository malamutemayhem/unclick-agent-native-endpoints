{
  "name": "@unclick/legalpass",
  "version": "0.1.0",
  "description": "LegalPass - 12-hat issue-spotter for AI-native teams. Twelve checks. One verdict. Plain English.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./schema": "./dist/schema.js",
    "./hat-library": "./dist/hat-library.js",
    "./verdict-pack": "./dist/verdict-pack.js",
    "./types": "./dist/types.js",
    "./tools": "./dist/tools/index.js",
    "./passguard/verdict-linter": "./dist/passguard/verdict-linter.js",
    "./passguard/disclaimer-banner": "./dist/passguard/disclaimer-banner.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
