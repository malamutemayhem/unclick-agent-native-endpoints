{
  "name": "@unclick/memory-mcp",
  "version": "0.2.1",
  "description": "Persistent cross-session memory for AI agents. Zero-config local mode or Supabase cloud sync. 6-layer architecture, 17 MCP tools.",
  "type": "module",
  "bin": {
    "unclick-memory-mcp": "./dist/index.js",
    "unclick-memory-setup": "./dist/setup.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md", "CLAUDE.md", "schema.sql"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "setup": "node dist/setup.js setup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["mcp", "memory", "ai-agent", "claude-code", "supabase", "persistent-memory", "unclick", "zero-config"],
  "author": "UnClick <hello@unclick.world>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/malamutemayhem/unclick-agent-native-endpoints"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@supabase/supabase-js": "^2.49.4",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/node": "^22.15.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  }
}
